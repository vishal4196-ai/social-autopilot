# ─── Claude ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-7

# ─── Postsyncer (handles LinkedIn + X via your connected accounts) ──
POSTSYNCER_API_KEY=ps_...
POSTSYNCER_WORKSPACE_ID=46763
# Connect your X + LinkedIn accounts in the Postsyncer dashboard first,
# then run `python -m scripts.bootstrap_postsyncer` to discover these IDs.
POSTSYNCER_LINKEDIN_ACCOUNT_ID=5091
POSTSYNCER_X_ACCOUNT_ID=5090
POSTSYNCER_THREADS_ACCOUNT_ID=5092    # optional — leave 0 to skip Threads

# ─── Telegram ────────────────────────────────────────────
# 1. In Telegram, message @BotFather, send /newbot, follow prompts. Copy the token.
# 2. Message @userinfobot to get your numeric Telegram user ID.
#    Only this user ID can post ideas; everyone else is ignored.
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_ALLOWED_USER_ID=123456789

# ─── GHL CTA ─────────────────────────────────────────────
CTA_URL=https://app.yourdomain.com/widget/form/abc123
CTA_LABEL=Book a free AI automation audit

# ─── Apify (viral discovery) ─────────────────────────────
APIFY_ENABLED=true
APIFY_TOKEN=apify_api_...
APIFY_LINKEDIN_ACTOR=scarletapi/linkedin-viral-posts-finder
APIFY_X_ACTOR=apidojo/twitter-scraper-lite
# Per-creator (handle-based) scrapers — used when you "follow" specific creators
APIFY_LINKEDIN_CREATOR_ACTOR=apimaestro/linkedin-profile-posts
APIFY_X_CREATOR_ACTOR=apidojo/twitter-user-scraper
# Single-post-by-URL scrapers — used when you paste a post URL to remix
APIFY_LINKEDIN_POST_ACTOR=apimaestro/linkedin-post-detail
APIFY_X_POST_ACTOR=apidojo/twitter-scraper-lite

# ─── Schedule (24h, in TIMEZONE) ─────────────────────────
POST_TIMES=09:00,13:00,18:00
TIMEZONE=America/Toronto

# ─── Research agent / weekly ideation cadence ────────────
# Runs once a week to drop a curated batch of ideas into Ideation.
RESEARCH_MODEL=claude-opus-4-7
ENABLE_WEB_SEARCH=true                 # let the research agent web-search live trends
IDEAS_PER_RUN=18                       # how many ideas the strategist drafts per run
WEEKLY_IDEATION_DAY=sun                # cron day_of_week (mon, tue, ..., sun)
WEEKLY_IDEATION_TIME=06:00             # HH:MM in TIMEZONE
WEEKLY_IDEATION_COUNT=15               # ideas auto-queued in Ideation per week
NOTIFY_TELEGRAM_AFTER_IDEATION=true    # Telegram nudge when the brief is ready
IDEAS_TO_QUEUE=6                       # fallback for manual research triggers

# ─── Web app (vishal.ai control panel) ───────────────────
# Railway injects PORT automatically. Leave blank locally to use 8080.
PORT=8080
# Long random string used to sign session cookies. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
WEB_SESSION_SECRET=change-me-to-a-long-random-string
# Login credentials for the web app (sole user — pick anything memorable):
WEB_USERNAME=vishal
WEB_PASSWORD=change-me-to-something-strong

# ─── Storage ─────────────────────────────────────────────
DB_PATH=/data/autopilot.db
